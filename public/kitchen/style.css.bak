/* ── RESET & BASE ── */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  background: #0a0e2a;
  color: #fff;
  font-family: 'Courier New', monospace;
  height: 100vh;
  overflow: hidden;
  user-select: none;
}

/* ── HEADER ── */
header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 24px;
  background: #0d1240;
  border-bottom: 3px solid #1a3a8a;
}

header h1 {
  font-size: 1.6rem;
  letter-spacing: 1px;
}

.header-right {
  display: flex;
  gap: 24px;
  font-size: 1.4rem;
  font-weight: bold;
  color: #8cf;
}

/* ── TABLE HEADER ── */
.table-header {
  display: flex;
  align-items: center;
  padding: 10px 24px;
  background: #1a3a8a;
  font-size: 1.2rem;
  font-weight: bold;
  letter-spacing: 2px;
  color: #aac4ff;
  border-bottom: 2px solid #2a4aaa;
}

/* ── COLUMN WIDTHS ── */
.col-num {
  width: 80px;
  min-width: 80px;
  text-align: center;
  flex-shrink: 0;
}

.col-time {
  width: 100px;
  min-width: 100px;
  text-align: center;
  flex-shrink: 0;
}

.col-order {
  flex: 1;
  overflow: hidden;
  position: relative;
}

/* ── ORDER ROWS ── */
#orders-container {
  flex: 1;
  overflow-y: auto;
}

.order-row {
  display: flex;
  align-items: center;
  padding: 14px 24px;
  font-size: 1.8rem;
  font-weight: bold;
  border-bottom: 2px solid #0d1240;
  animation: fadeIn 0.3s ease;
}

/* Alternating stripes */
.order-row:nth-child(odd) {
  background: #142060;
}

.order-row:nth-child(even) {
  background: #1a2a7a;
}

.order-row .col-num {
  color: #ffdd57;
  font-size: 2rem;
}

.order-row .col-time {
  color: #8cf;
}

.order-row .col-order {
  color: #fff;
  white-space: nowrap;
}

/* ── MODIFIED INDICATOR ── */
.order-row.was-modified {
  background: #2a1a60;
}

.order-row.was-modified:nth-child(odd) {
  background: #2a1a60;
}

.order-row.was-modified:nth-child(even) {
  background: #321e70;
}

/* ── SCROLLING LONG TEXT ── */
.order-text {
  display: inline-block;
  white-space: nowrap;
}

.order-text.scrolling {
  animation: marquee 10s ease-in-out infinite;
}

@keyframes marquee {
  0%   { transform: translateX(0); }
  15%  { transform: translateX(0); }
  50%  { transform: translateX(calc(var(--overflow, 0px) * -1)); }
  85%  { transform: translateX(calc(var(--overflow, 0px) * -1)); }
  100% { transform: translateX(0); }
}

/* ── COMPLETING ANIMATION ── */
.order-row.completing {
  opacity: 0;
  transform: translateX(100%);
  transition: all 0.5s ease;
}

.order-row.cancelled {
  background: #4a1020 !important;
  animation: none;
}

.order-row.cancelled .col-order {
  color: #ff4444;
}

/* ── EMPTY STATE ── */
.empty-message {
  text-align: center;
  font-size: 1.6rem;
  color: #4a5a9a;
  padding: 80px 24px;
}

/* ── FADE IN ── */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(-10px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ── CONNECTION STATUS ── */
.connection-status {
  position: fixed;
  bottom: 12px;
  right: 16px;
  padding: 6px 14px;
  border-radius: 20px;
  font-size: 0.9rem;
  font-family: sans-serif;
}

.connection-status.connected {
  background: rgba(0, 180, 80, 0.2);
  color: #4f8;
}

.connection-status.disconnected {
  background: rgba(220, 40, 40, 0.3);
  color: #f66;
}

/* ── SCROLLBAR (subtle) ── */
#orders-container::-webkit-scrollbar {
  width: 6px;
}

#orders-container::-webkit-scrollbar-thumb {
  background: #1a3a8a;
  border-radius: 3px;
}

#orders-container::-webkit-scrollbar-track {
  background: transparent;
}